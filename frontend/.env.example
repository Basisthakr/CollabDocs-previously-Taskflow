# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# Base URL of the Spring Boot REST API (no trailing slash)
# Development default: http://localhost:8080
VITE_API_URL=http://localhost:8080

# WebSocket endpoint exposed by the Spring Boot server
# Must use ws:// (or wss:// for TLS in production)
# Development default: ws://localhost:8080/docs/ws
VITE_WS_URL=ws://localhost:8080/docs/ws
