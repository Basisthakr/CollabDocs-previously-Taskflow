# ============================================================
# .env.example — docker-compose environment variables
#
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.
#
# Local dev:  leave the localhost defaults as-is.
# AWS EC2:    replace every <EC2-PUBLIC-IP> with your instance's
#             public IPv4 address (or domain name if you have one).
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# ---- JWT ----
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_256_bit_base64_encoded_secret_key
JWT_EXPIRATION=86400000          # 1 day in ms
JWT_REFRESH_EXPIRATION=604800000 # 7 days in ms

# ---- Hibernate DDL ----
# 'update'    — auto-migrate schema (dev / first run)
# 'validate'  — fail fast if schema is wrong (production)
DDL_AUTO=update

# ---- CORS ----
# The origin that the backend will accept cross-origin requests from.
# All traffic goes through nginx on port 3000 — backend is not exposed.
#   Local:  http://localhost:3000
#   AWS:    http://<EC2-PUBLIC-IP>:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Email / 2-FA (optional — leave blank to skip OTP emails) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ---- Vite (baked into the frontend JS bundle at build time) ----
# Must be the public address of the server — reachable from the user's browser.
# nginx proxies /api/, /auth/, /docs/ws to the backend, so everything goes
# through port 3000 (no need to expose port 8080 publicly).
#   Local:  http://localhost:3000   /  ws://localhost:3000/docs/ws
#   AWS:    http://<EC2-PUBLIC-IP>:3000  /  ws://<EC2-PUBLIC-IP>:3000/docs/ws
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000/docs/ws
